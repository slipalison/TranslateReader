<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TranslateReader"
             xmlns:utilities="clr-namespace:TranslateReader.Utilities"
             x:Class="TranslateReader.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <utilities:HtmlStringConverter x:Key="HtmlStringConverter" />
            <utilities:StringIsNullOrEmptyConverter x:Key="StringIsNullOrEmptyConverter" />
            <utilities:StringIsNotNullOrEmptyConverter x:Key="StringIsNotNullOrEmptyConverter" />
            <utilities:PercentageToDecimalConverter x:Key="PercentageToDecimalConverter" />
            <utilities:FilePathToImageSourceConverter x:Key="FilePathToImageSourceConverter" />
            <x:Boolean x:Key="True">True</x:Boolean>
            <x:Boolean x:Key="False">False</x:Boolean>
        </ResourceDictionary>
    </Application.Resources>
</Application>

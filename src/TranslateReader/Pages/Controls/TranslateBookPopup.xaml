<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TranslateReader.Pages.Controls.TranslateBookPopup">

    <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A1A2E}"
            Padding="24"
            StrokeShape="RoundRectangle 12"
            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
            WidthRequest="320">

        <VerticalStackLayout Spacing="16">
            <Label Text="Traduzir livro"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Label x:Name="BookTitleLabel"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#666666, Dark=#999999}"
                   MaxLines="2"
                   LineBreakMode="TailTruncation" />

            <BoxView HeightRequest="1"
                     Color="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" />

            <VerticalStackLayout Spacing="4">
                <Label Text="Idioma de origem" FontSize="14" />
                <Picker x:Name="SourcePicker" FontSize="14" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4">
                <Label Text="Idioma de destino" FontSize="14" />
                <Picker x:Name="TargetPicker" FontSize="14" />
            </VerticalStackLayout>

            <HorizontalStackLayout Spacing="12" HorizontalOptions="End" Margin="0,8,0,0">
                <Button Text="Cancelar"
                        Clicked="OnCancelClicked"
                        BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A3E}"
                        TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#E4E4E7}"
                        CornerRadius="8"
                        Padding="16,8"
                        FontSize="14" />
                <Button Text="Traduzir"
                        Clicked="OnTranslateClicked"
                        BackgroundColor="#2563EB"
                        TextColor="White"
                        CornerRadius="8"
                        Padding="16,8"
                        FontSize="14" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Border>
</ContentView>

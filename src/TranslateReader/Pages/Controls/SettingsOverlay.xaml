<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TranslateReader.Pages.Controls.SettingsOverlay">

    <Grid>
        <!-- Fundo semi-transparente clicável para fechar -->
        <BoxView Color="Black" Opacity="0.4">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackdropTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Painel de configurações ancorado na parte inferior -->
        <Border VerticalOptions="End"
                HorizontalOptions="Fill"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A1A2E}"
                Padding="20,16,20,32"
                Margin="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16,16,0,0" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="16">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="Configurações de leitura"
                           FontSize="16"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="✕"
                            Clicked="OnCloseClicked"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#E4E4E7}"
                            FontSize="18"
                            Padding="8,0"
                            HeightRequest="36" />
                </Grid>

                <BoxView HeightRequest="1"
                         Color="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" />

                <!-- Seletor de Tema -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="Tema" FontSize="14" />
                    <HorizontalStackLayout Spacing="12">
                        <Button x:Name="LightThemeButton"
                                Text="☀ Claro"
                                Clicked="OnLightThemeClicked"
                                BackgroundColor="#FFFFFF"
                                TextColor="#1A1A1A"
                                BorderColor="#2563EB"
                                BorderWidth="2"
                                CornerRadius="20"
                                Padding="12,6"
                                FontSize="12" />
                        <Button x:Name="DarkThemeButton"
                                Text="☾ Escuro"
                                Clicked="OnDarkThemeClicked"
                                BackgroundColor="#1A1A2E"
                                TextColor="#E4E4E7"
                                BorderColor="#1A1A2E"
                                BorderWidth="2"
                                CornerRadius="20"
                                Padding="12,6"
                                FontSize="12" />
                        <Button x:Name="SepiaThemeButton"
                                Text="☕ Sépia"
                                Clicked="OnSepiaThemeClicked"
                                BackgroundColor="#F4ECD8"
                                TextColor="#5B4636"
                                BorderColor="#F4ECD8"
                                BorderWidth="2"
                                CornerRadius="20"
                                Padding="12,6"
                                FontSize="12" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Modo de leitura -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="Modo de leitura" FontSize="14" />
                    <HorizontalStackLayout Spacing="12">
                        <Button x:Name="ScrollModeButton"
                                Text="Rolagem"
                                Clicked="OnScrollModeClicked"
                                BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A3E}"
                                TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#E4E4E7}"
                                BorderColor="#2563EB"
                                BorderWidth="2"
                                CornerRadius="20"
                                Padding="12,6"
                                FontSize="12" />
                        <Button x:Name="PaginatedModeButton"
                                Text="Paginado"
                                Clicked="OnPaginatedModeClicked"
                                BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A3E}"
                                TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#E4E4E7}"
                                BorderColor="Transparent"
                                BorderWidth="2"
                                CornerRadius="20"
                                Padding="12,6"
                                FontSize="12" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Fonte -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Fonte" FontSize="14" />
                    <Picker x:Name="FontPicker"
                            SelectedIndexChanged="OnFontPickerChanged"
                            FontSize="14" />
                </VerticalStackLayout>

                <!-- Tamanho da fonte -->
                <VerticalStackLayout Spacing="4">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Tamanho da fonte" FontSize="14" />
                        <Label Grid.Column="1" x:Name="FontSizeLabel" FontSize="14" />
                    </Grid>
                    <Slider x:Name="FontSizeSlider"
                            Minimum="12"
                            Maximum="32"
                            ValueChanged="OnFontSizeChanged" />
                </VerticalStackLayout>

                <!-- Espaçamento entre linhas -->
                <VerticalStackLayout Spacing="4">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Espaçamento de linhas" FontSize="14" />
                        <Label Grid.Column="1" x:Name="LineSpacingLabel" FontSize="14" />
                    </Grid>
                    <Slider x:Name="LineSpacingSlider"
                            Minimum="1.0"
                            Maximum="3.0"
                            ValueChanged="OnLineSpacingChanged" />
                </VerticalStackLayout>

                <!-- Espaçamento entre letras -->
                <VerticalStackLayout Spacing="4">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Espaçamento de letras" FontSize="14" />
                        <Label Grid.Column="1" x:Name="LetterSpacingLabel" FontSize="14" />
                    </Grid>
                    <Slider x:Name="LetterSpacingSlider"
                            Minimum="-1"
                            Maximum="3"
                            ValueChanged="OnLetterSpacingChanged" />
                </VerticalStackLayout>

                <!-- Espaçamento entre palavras -->
                <VerticalStackLayout Spacing="4">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Espaçamento de palavras" FontSize="14" />
                        <Label Grid.Column="1" x:Name="WordSpacingLabel" FontSize="14" />
                    </Grid>
                    <Slider x:Name="WordSpacingSlider"
                            Minimum="0"
                            Maximum="10"
                            ValueChanged="OnWordSpacingChanged" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
